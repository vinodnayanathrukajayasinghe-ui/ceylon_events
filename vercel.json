{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.png|robots\\.txt|sitemap\\.xml|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/"
    }
  ]
}
